pkgname=rustup-git
_gitname=rustup
pkgver=1.29.0.r18.g6f8931c6
pkgrel=2
pkgdesc="The Rust toolchain installer"
arch=('x86_64')
url="https://github.com/rust-lang/rustup"
license=('MIT' 'Apache-2.0')
depends=(
  'glibc'
  'libgcc'
  'xz'
  'zstd'
)
makedepends=('cargo' 'git')
optdepends=('lldb: rust-lldb script'
            'gdb: rust-gdb script'
            'gcc: build executables for most targets' # x86_64-unknown-linux-* but also most Unix-likes
            'mingw-w64-gcc: {i686,x86_64}-pc-windows-gnu targets'
            'aarch64-linux-gnu-gcc: aarch64-unknown-linux-* targets')
provides=('rust' 'cargo' 'rust-nightly' 'cargo-nightly' 'rustfmt' 'rust-src'
          'lib32-rust-libs' 'rust-musl' 'rust-wasm' 'rustup' 'rust-analyzer')
conflicts=('rust' 'cargo' 'rustfmt' 'rust-nightly' 'rust-nightly-bin' 'rustup' 'rust-analyzer')
install='post.install'
source=("${_gitname}::git+https://github.com/rust-lang/rustup.git"
        "rustup-profile.sh"
        "rustup-profile.fish"
        "list-proxy-names.rs")
sha512sums=('SKIP'
            '18d5b4ab9a032cb43fd0b59fb553a878068981534e549935c5ff4a12dc2f74849ce36367eb59e670d674a19a7d4bc0056d0694d7f87ede187416c2ffcbb20355'
            '01477110cc630b2fbd60b45e53d5fddea1b96d56c7dd318c9dcd0fcb3401778df0f2ffaeda09ed57c3d09723e7e7b9080028ccde7ebd7774c7098e6fc7900669'
            'fdc9750850e8265409f2fcacf3c7f59e82b619ed40cef0c82944e08c17266107327813fb283c909b3b0821501fac064d9e3618060d688aa7c76cf16a36244626')
options=(!lto)

pkgver() {
  cd "$srcdir/$_gitname"
  git describe --long --tags | sed 's/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
   cd "$srcdir/$_gitname"
   cp ../list-proxy-names.rs src/bin
   export RUSTUP_TOOLCHAIN=stable
   cargo fetch --locked --target "$CARCH-unknown-linux-gnu"
}

build() {
  cd "$srcdir/$_gitname"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  export ZSTD_SYS_USE_PKG_CONFIG=1
  cargo build --release --no-default-features --features reqwest-rustls-tls --features no-self-update --bin rustup-init
}

package() {
  cd "$srcdir/$_gitname"
  install -d "${pkgdir}/usr/lib/$_gitname/bin"
  install -Dm755 "target/release/rustup-init" "${pkgdir}/usr/bin/rustup"
  for link in "${_binlinks[@]}"; do
      ln -s /usr/bin/rustup "${pkgdir}/usr/bin/${link}"
  done

  # Special treatment for rust-analyzer to still allow the separate package version to be used.
  ln -s /usr/bin/rustup "${pkgdir}/usr/lib/$_gitname/bin/rust-analyzer"

  install -Dm644 "$srcdir/$_gitname-profile.sh" "$pkgdir/etc/profile.d/$_gitname.sh"
  install -Dm644 "$srcdir/$_gitname-profile.fish" "$pkgdir/usr/share/fish/vendor_conf.d/$_gitname.fish"

  # Generate completion files.
  mkdir -p "$pkgdir/usr/share/bash-completion/completions"
  "$pkgdir"/usr/bin/rustup completions bash > "$pkgdir/usr/share/bash-completion/completions/rustup"
  "$pkgdir"/usr/bin/rustup completions bash cargo > "$pkgdir/usr/share/bash-completion/completions/cargo"
  mkdir -p "$pkgdir/usr/share/fish/vendor_completions.d"
  "$pkgdir"/usr/bin/rustup completions fish > "$pkgdir/usr/share/fish/vendor_completions.d/rustup.fish"
  mkdir -p "$pkgdir/usr/share/zsh/site-functions"
  "$pkgdir"/usr/bin/rustup completions zsh > "$pkgdir/usr/share/zsh/site-functions/_rustup"
  "$pkgdir"/usr/bin/rustup completions zsh cargo > "$pkgdir/usr/share/zsh/site-functions/_cargo"

  install -Dm644 LICENSE-MIT "${pkgdir}"/usr/share/licenses/$_gitname/LICENSE-MIT
  install -Dm644 LICENSE-APACHE "${pkgdir}"/usr/share/licenses/$_gitname/LICENSE-APACHE
}

