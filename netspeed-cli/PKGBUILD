# Maintainer: Piotr Górski <lucjan.lucjanov@gmail.com>

pkgname=netspeed-cli
pkgver=0.10.3
pkgrel=1
pkgdesc='Command-line interface for testing internet bandwidth using speedtest.net'
url='https://github.com/mapleDevJS/netspeed-cli'
arch=('x86_64')
license=('MIT')
makedepends=(
  cargo
  git
)
options=(!lto)
source=("git+https://github.com/mapleDevJS/netspeed-cli#tag=v$pkgver")
sha256sums=('b1f9f14c15ce5cf2bab4ff023efb00ae37ffa34b35cd24ca4bc5805052be7b3a')

prepare() {
  cd $pkgname
  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd $pkgname
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build --release --frozen --all-features
}

package() {
  cd $pkgname
  export RUSTUP_TOOLCHAIN=stable
  cargo install --no-track --frozen --all-features --root "$pkgdir/usr/" --path .
}
