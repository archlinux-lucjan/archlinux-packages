# Available profiles: “release”, “release-tiny”, “release-fast“
# See: https://github.com/sched-ext/scx/blob/main/Cargo.toml
_mode=release

pkgname=scx-scheds-git
_gitname=scx
pkgver=1.1.0.r435.g4686b020
pkgrel=1
pkgdesc='sched_ext schedulers and tools'
url='https://github.com/sched-ext/scx'
arch=('x86_64')
license=('GPL-2.0-only')
depends=(
  jq
  libseccomp
  libelf
  zlib
)
makedepends=(
  cargo
  clang
  git
  llvm
  llvm-libs
  python
)
optdepends=(
'scx-tools: scx_loader and scxctl - A DBUS Interface for Managing sched_ext Schedulers '
)
options=(!lto)
provides=("scx-scheds")
conflicts=("scx-scheds")
source=("git+https://github.com/sched-ext/scx")
sha256sums=('SKIP')

_backports=(
afcb761728badd144076f8b4aded728313a67db3 # scx_cake: squash rebased nightly update
104bc17d04a7c3bca516d2278fd013209e66566a # scheds: add --completions flag for shell completion generation
6c027686944cb780e5878acae6bc7098f00c2f03 # scheds: Introduce scx_maestro
2dbbb590fccef95286b126a1c0680f7d1eac5a3d # scx_maestro: Honor cgroup cpu.weight for tasks and sub-schedulers
5140458b82bab0766f23b171ae0b77d6fb98c56b # scx_maestro: Allow to enable/disable NUMA and SMT optimizations
5d6c2f62a62151753a1052a4415dd7adb3186fb2 # scx_maestro: Don't update deadline in case of re-enqueue
2a71e9e45512458dace3a69a1462b41166fdd387 # scx_maestro: Introduce completely fair scheduling
5cdff0f3dccc78f1cbacdce26b49f1b8a25e6fef # scx_maestro: Make enqueue + CPU kick more reliable
67df1d7c35306da26d44e961cff408e30f26779b # Cargo: fix formatting
717f2bbb719f15148a4b89ebe738732c9e0211b2 # scx_maestro: add --completions flag for shell completion generation
94306c2e2f448b288a4447caaf1ffe9d8345aa18 # Cargo: update dependencies to latest versions
)

_reverts=(
)

pkgver() {
  cd $_gitname
  git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd $_gitname

  local _c _l
   for _c in "${_backports[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git cherry-pick --mainline 1 --no-commit "${_c}"
   done
   for _c in "${_reverts[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git revert --mainline 1 --no-commit "${_c}"
   done

  local src
   for src in "${source[@]}"; do
     src="${src%%::*}"
     src="${src##*/}"
     [[ $src = *.patch ]] || continue
     echo "Applying patch $src..."
     patch -Np1 < "../$src"
   done

  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd $_gitname
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build \
     --profile=$_mode \
     --frozen \
     --all-features \
     --workspace \
     --exclude scx_rlfifo \
     --exclude scxcash \
     --exclude xtask \
     --exclude vmlinux_docify \
     --exclude scx_arena_selftests
}

package() {
  cd $_gitname

  # Install all built executables (skip .so and .d files)
  find target/$_mode \
    -maxdepth 1 -type f -executable ! -name '*.so' \
    -exec install -Dm755 -t "$pkgdir/usr/bin/" {} +
}
