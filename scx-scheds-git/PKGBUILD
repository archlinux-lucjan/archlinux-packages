f0915a6d494b542b71c06982c582d85007318638 # scx_flash: Use SCX_DSQ_LOCAL to direct dispatch per-CPU tasks
685156e194366bbb4d4439c59f4526d11d3e2e67 # Cargo: fix formatting
1199336a4b9d8b4fb7047992306b100d4c4bc65a # scx_maestro: add --completions flag for shell completion generation
