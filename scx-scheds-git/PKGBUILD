cedd32d154cfee4dd1e3133bff00b86a2a681ba2 # scx_cake: merge nightly updates after upstream rebase
6f4608a8fbc6a268543d9ab13317fbea2f49d930 # scx_pandemonium: bump to 5.7.0
2614e85c4908b378b05f4b8fbf8deb0243b90bac # scx_pandemonium: bump to 5.8.0
1e58266cc802330a08e85ae9d80666616b9a8c9a # scheds: add --completions flag for shell completion generation
24a26f8bfc2e629b130e6f1e4c938591eecc796b # scheds: Introduce scx_maestro
57042337141d8427e7139ecb307da5d6faf3183f # scx_maestro: Honor cgroup cpu.weight for tasks and sub-schedulers
aaa2a8cc76ccb8e29c62a61bf8b1d5659ca7448d # scx_maestro: Allow to enable/disable NUMA and SMT optimizations
3d728c2c1fe2ea86c8f275eedc5465374492fbb0 # scx_maestro: Don't update deadline in case of re-enqueue
cd9acd313af5c50741c2e3f965ff990e977e1d66 # scx_maestro: Introduce completely fair scheduling
2807d7c71b0c6ec062ca1b86e08c8df7d7b51952 # scx_maestro: Make enqueue + CPU kick more reliable
543d21d689d8522b8aac419e64603731fcd9ac92 # scx_flash: Use SCX_DSQ_LOCAL to direct dispatch per-CPU tasks
3dd21753f4742a7cf23d9ed445bba393929750be # Cargo: fix formatting
49a1711de52f0e6d1f43ba3cc70f144b5ad5cb51 # scx_maestro: add --completions flag for shell completion generation
ec863bb117e3b2d5f4cbe8e4ecf0789c000a47bc # Cargo: update dependencies to latest versions
)

_reverts=(
)

pkgver() {
  cd $_gitname
  git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd $_gitname

  local _c _l
   for _c in "${_backports[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git cherry-pick --mainline 1 --no-commit "${_c}"
   done
   for _c in "${_reverts[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git revert --mainline 1 --no-commit "${_c}"
   done

  local src
   for src in "${source[@]}"; do
     src="${src%%::*}"
     src="${src##*/}"
     [[ $src = *.patch ]] || continue
     echo "Applying patch $src..."
     patch -Np1 < "../$src"
   done

  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd $_gitname
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build \
     --profile=$_mode \
     --frozen \
     --all-features \
     --workspace \
     --exclude scx_rlfifo \
     --exclude scxcash \
     --exclude xtask \
     --exclude vmlinux_docify \
     --exclude scx_arena_selftests
}

package() {
  cd $_gitname

  # Install all built executables (skip .so and .d files)
  find target/$_mode \
    -maxdepth 1 -type f -executable ! -name '*.so' \
    -exec install -Dm755 -t "$pkgdir/usr/bin/" {} +
}
