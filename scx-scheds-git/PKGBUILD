# Available profiles: “release”, “release-tiny”, “release-fast“
# See: https://github.com/sched-ext/scx/blob/main/Cargo.toml
_mode=release

pkgname=scx-scheds-git
_gitname=scx
pkgver=1.1.0.r372.ga08c9e27
pkgrel=2
pkgdesc='sched_ext schedulers and tools'
url='https://github.com/sched-ext/scx'
arch=('x86_64')
license=('GPL-2.0-only')
depends=(
  jq
  libseccomp
  libelf
  zlib
)
makedepends=(
  cargo
  clang
  git
  llvm
  llvm-libs
  python
)
optdepends=(
'scx-tools: scx_loader and scxctl - A DBUS Interface for Managing sched_ext Schedulers '
)
options=(!lto)
provides=("scx-scheds")
conflicts=("scx-scheds")
source=("git+https://github.com/sched-ext/scx")
sha256sums=('SKIP')

_backports=(
851dcb15edce5c43c75789b819e8a088af16c324 # scx_pandemonium: bump to 5.7.0
fe3481b31786fc84cc604862cdf8ff5cd08864b4 # scheds: add --completions flag for shell completion generation
1b25e508a922b01de85a14ea1072c1f2584adf75 # scheds: Introduce scx_maestro
cc7d95a964662c330bf4bd5c260700f2aa594c6b # scx_maestro: Honor cgroup cpu.weight for tasks and sub-schedulers
4b07e5915054fdfa3cc7907c5e88a46fc73b705b # scx_maestro: Allow to enable/disable NUMA and SMT optimizations
e7d6e4246998bebed2dd7a079f3f424c699a47c4 # scx_maestro: Don't update deadline in case of re-enqueue
93fe0cfd05c56c3a08b89ea6d5e8884d5735bf14 # scx_maestro: Introduce completely fair scheduling
f73c3390848c56adbd247e79b718ff788f2e3787 # scx_maestro: Make enqueue + CPU kick more reliable
ef3e2d07945f979205075e9cabfe3ad28c05fd89 # scx_flash: Use SCX_DSQ_LOCAL to direct dispatch per-CPU tasks
1c6a6718a828742d7fe0b1ce60ae30cc2543d842 # Cargo: fix formatting
b22eadc784aedcd1c308cec9b182bafd77b46323 # scx_maestro: add --completions flag for shell completion generation
88cbd06a061a0a06a0fc010ed850b1368fdc0a71 # Cargo: update dependencies to latest versions
)

_reverts=(
)

pkgver() {
  cd $_gitname
  git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd $_gitname

  local _c _l
   for _c in "${_backports[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git cherry-pick --mainline 1 --no-commit "${_c}"
   done
   for _c in "${_reverts[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git revert --mainline 1 --no-commit "${_c}"
   done

  local src
   for src in "${source[@]}"; do
     src="${src%%::*}"
     src="${src##*/}"
     [[ $src = *.patch ]] || continue
     echo "Applying patch $src..."
     patch -Np1 < "../$src"
   done

  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd $_gitname
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build \
     --profile=$_mode \
     --frozen \
     --all-features \
     --workspace \
     --exclude scx_rlfifo \
     --exclude scxcash \
     --exclude xtask \
     --exclude vmlinux_docify \
     --exclude scx_arena_selftests
}

package() {
  cd $_gitname

  # Install all built executables (skip .so and .d files)
  find target/$_mode \
    -maxdepth 1 -type f -executable ! -name '*.so' \
    -exec install -Dm755 -t "$pkgdir/usr/bin/" {} +
}
