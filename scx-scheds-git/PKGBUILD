409cd3bc801eb0b7cbd0bb86d622d828312ddadd # scx_cosmos: Tune default settings for latency
62e15578c23742dd5627ca280bcb7382c52f0936 # fix: correctness improvements and scx_loader compatibility
73340c5ea864c882e381282d66deb72a661d8058 # cake_stopping: hot-path optimization — -25% insns, -40% spills, -100% divs
c6ea5120a62a0d49932cc4b8a1835a8392a2853b # cake_stopping: zero-spill architectural decomposition (42→0 spills, 419→30 insns)
37a2617d8dfd1b9372508d4796d09f3d7dc5be94 # scx_cake: zero register spills across all BPF functions
353648255a543d47dd0ccb5c237ba82fcbfa542a # scx_cake: hot-path instruction audit — 30% reduction
14d8e83cdb59014b75bf0c60a4ff2bd4f3cbc0e9 # scx_cake: cold-path audit — gate init_task tctx writes behind CAKE_STATS_ENABLED
f7d1e96d8230328acc79bd568635dfaf8cdac33e # scx_cake: cold-path audit — remove dead cached_cpumask, fuse stores, branchless PF_KTHREAD
d662e06bccb9ac29a63a999238cbb9a841efcb56 # P2: hot path -63 insns (593->530, 10.6%)
35ccb68d56423fd796304c1fc5086582436ac4a2 # fix(cake): anti-starvation — remove p->scx.slice write from stopping
e10e080d3543abc83dfcb0179d1a2c92b234c372 # cargo: fix formatting
)

_reverts=(
)

pkgver() {
  cd $_gitname
  git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd $_gitname

  local _c _l
   for _c in "${_backports[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git cherry-pick --mainline 1 --no-commit "${_c}"
   done
   for _c in "${_reverts[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git revert --mainline 1 --no-commit "${_c}"
   done

  local src
   for src in "${source[@]}"; do
     src="${src%%::*}"
     src="${src##*/}"
     [[ $src = *.patch ]] || continue
     echo "Applying patch $src..."
     patch -Np1 < "../$src"
   done

  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd $_gitname
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build \
     --profile=$_mode \
     --frozen \
     --all-features \
     --workspace \
     --exclude scx_rlfifo \
     --exclude scx_wd40 \
     --exclude scxcash \
     --exclude xtask \
     --exclude vmlinux_docify \
     --exclude scx_arena_selftests
}

package() {
  cd $_gitname

  # Install all built executables (skip .so and .d files)
  find target/$_mode \
    -maxdepth 1 -type f -executable ! -name '*.so' \
    -exec install -Dm755 -t "$pkgdir/usr/bin/" {} +
}
