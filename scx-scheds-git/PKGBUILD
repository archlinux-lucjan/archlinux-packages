# Available profiles: “release”, “release-tiny”, “release-fast“
# See: https://github.com/sched-ext/scx/blob/main/Cargo.toml
_mode=release

pkgname=scx-scheds-git
_gitname=scx
pkgver=1.1.0.r372.ga08c9e27
pkgrel=4
pkgdesc='sched_ext schedulers and tools'
url='https://github.com/sched-ext/scx'
arch=('x86_64')
license=('GPL-2.0-only')
depends=(
  jq
  libseccomp
  libelf
  zlib
)
makedepends=(
  cargo
  clang
  git
  llvm
  llvm-libs
  python
)
optdepends=(
'scx-tools: scx_loader and scxctl - A DBUS Interface for Managing sched_ext Schedulers '
)
options=(!lto)
provides=("scx-scheds")
conflicts=("scx-scheds")
source=("git+https://github.com/sched-ext/scx")
sha256sums=('SKIP')

_backports=(
29327a4a9dd782f0b03c3ff84ff2457db57ffd7d # scx_pandemonium: bump to 5.7.0
09e7a3c1921d53ab9f4039cafa42950475965961 # scx_pandemonium: silence warning
1ac1c4ed1e47c068ae90675fd7ee3a1ab29c4de7 # scheds: add --completions flag for shell completion generation
be75ef9dbc17d055ff74115a3d36e91687f755a5 # scheds: Introduce scx_maestro
cc5e6ec2a54c9352d05391625e4c0c4032e6d357 # scx_maestro: Honor cgroup cpu.weight for tasks and sub-schedulers
531e9303effeeeca1ff2aa4598e00c5ec81ecfb2 # scx_maestro: Allow to enable/disable NUMA and SMT optimizations
5a6e53c63bb8c6772f3f79410f934e849f4640f3 # scx_maestro: Don't update deadline in case of re-enqueue
42fceb01bb917a619601d13899d02cf73d5bfca8 # scx_maestro: Introduce completely fair scheduling
d4202b3879eb5ed34a2bf12ea977662f631c9eb3 # scx_maestro: Make enqueue + CPU kick more reliable
ab5abe7607d17847c2dddb787085cdb498cee842 # scx_flash: Use SCX_DSQ_LOCAL to direct dispatch per-CPU tasks
0d5dc491972aeabfe7127742e14dcd7ea46cd7dd # Cargo: fix formatting
9d9d761cb1d30946b0b15c94db09bc64aec715d8 # scx_maestro: add --completions flag for shell completion generation
89f20fb9fd2b26ccdae9415ab4e9030d8a5c659b # Cargo: update dependencies to latest versions
)

_reverts=(
)

pkgver() {
  cd $_gitname
  git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd $_gitname

  local _c _l
   for _c in "${_backports[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git cherry-pick --mainline 1 --no-commit "${_c}"
   done
   for _c in "${_reverts[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git revert --mainline 1 --no-commit "${_c}"
   done

  local src
   for src in "${source[@]}"; do
     src="${src%%::*}"
     src="${src##*/}"
     [[ $src = *.patch ]] || continue
     echo "Applying patch $src..."
     patch -Np1 < "../$src"
   done

  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd $_gitname
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build \
     --profile=$_mode \
     --frozen \
     --all-features \
     --workspace \
     --exclude scx_rlfifo \
     --exclude scxcash \
     --exclude xtask \
     --exclude vmlinux_docify \
     --exclude scx_arena_selftests
}

package() {
  cd $_gitname

  # Install all built executables (skip .so and .d files)
  find target/$_mode \
    -maxdepth 1 -type f -executable ! -name '*.so' \
    -exec install -Dm755 -t "$pkgdir/usr/bin/" {} +
}
