# Available profiles: “release”, “release-tiny”, “release-fast“
# See: https://github.com/sched-ext/scx/blob/main/Cargo.toml
_mode=release

pkgname=scx-scheds-git
_gitname=scx
pkgver=1.1.0.r372.ga08c9e27
pkgrel=6
pkgdesc='sched_ext schedulers and tools'
url='https://github.com/sched-ext/scx'
arch=('x86_64')
license=('GPL-2.0-only')
depends=(
  jq
  libseccomp
  libelf
  zlib
)
makedepends=(
  cargo
  clang
  git
  llvm
  llvm-libs
  python
)
optdepends=(
'scx-tools: scx_loader and scxctl - A DBUS Interface for Managing sched_ext Schedulers '
)
options=(!lto)
provides=("scx-scheds")
conflicts=("scx-scheds")
source=("git+https://github.com/sched-ext/scx")
sha256sums=('SKIP')

_backports=(
0c5da5009e2b5e1ca5de01b4b9520c9a00604a24 # scx_pandemonium: bump to 5.7.0
74869fee7c9015046b5cb4b9e12316c17fc28848 # scheds: add --completions flag for shell completion generation
8617ced516dd616697cb53b64984bf2f69454359 # scheds: Introduce scx_maestro
065facee79d08f1d890d20bc386816dd55fd9fdb # scx_maestro: Honor cgroup cpu.weight for tasks and sub-schedulers
0aa3424f76db6c5addceb381a1c8cdcf25dd9efe # scx_maestro: Allow to enable/disable NUMA and SMT optimizations
8416a3239204474af2da2328e6876a622006286f # scx_maestro: Don't update deadline in case of re-enqueue
36a63cbabe6b45a4bec224c39b0698affab43971 # scx_maestro: Introduce completely fair scheduling
1cab2fa3bbe2b59cb2f56117d8259671279b149e # scx_maestro: Make enqueue + CPU kick more reliable
c742e6c514159845b384986d4058bb0b21ad7294 # scx_flash: Use SCX_DSQ_LOCAL to direct dispatch per-CPU tasks
a286f8652687d339eaf20bfb6fb0715f5b0d34a4 # Cargo: fix formatting
fdfed434df38a605b29fd9e8e32e9e9a650a4ffd # scx_maestro: add --completions flag for shell completion generation
c7b72bf4e03e25c778f73cd2988c69ebb654bf3e # Cargo: update dependencies to latest versions
)

_reverts=(
)

pkgver() {
  cd $_gitname
  git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd $_gitname

  local _c _l
   for _c in "${_backports[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git cherry-pick --mainline 1 --no-commit "${_c}"
   done
   for _c in "${_reverts[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git revert --mainline 1 --no-commit "${_c}"
   done

  local src
   for src in "${source[@]}"; do
     src="${src%%::*}"
     src="${src##*/}"
     [[ $src = *.patch ]] || continue
     echo "Applying patch $src..."
     patch -Np1 < "../$src"
   done

  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd $_gitname
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build \
     --profile=$_mode \
     --frozen \
     --all-features \
     --workspace \
     --exclude scx_rlfifo \
     --exclude scxcash \
     --exclude xtask \
     --exclude vmlinux_docify \
     --exclude scx_arena_selftests
}

package() {
  cd $_gitname

  # Install all built executables (skip .so and .d files)
  find target/$_mode \
    -maxdepth 1 -type f -executable ! -name '*.so' \
    -exec install -Dm755 -t "$pkgdir/usr/bin/" {} +
}
