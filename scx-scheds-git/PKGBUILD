# Available profiles: “release”, “release-tiny”, “release-fast“
# See: https://github.com/sched-ext/scx/blob/main/Cargo.toml
_mode=release

pkgname=scx-scheds-git
_gitname=scx
pkgver=1.1.0.r431.g6b5bcde8
pkgrel=1
pkgdesc='sched_ext schedulers and tools'
url='https://github.com/sched-ext/scx'
arch=('x86_64')
license=('GPL-2.0-only')
depends=(
  jq
  libseccomp
  libelf
  zlib
)
makedepends=(
  cargo
  clang
  git
  llvm
  llvm-libs
  python
)
optdepends=(
'scx-tools: scx_loader and scxctl - A DBUS Interface for Managing sched_ext Schedulers '
)
options=(!lto)
provides=("scx-scheds")
conflicts=("scx-scheds")
source=("git+https://github.com/sched-ext/scx")
sha256sums=('SKIP')

_backports=(
9d8868a1c582160a7afad30d062624853faa9e1e # scx_cake: squash rebased nightly update
37e8a0d9fd4ec6a4646e0b11740816c870c5205f # scheds: add --completions flag for shell completion generation
96518bdcc3c0dbaa25334ec5bd0de6235075aa93 # scheds: Introduce scx_maestro
08d1204beacac578c7e63c71b2e2e6dd329f28f4 # scx_maestro: Honor cgroup cpu.weight for tasks and sub-schedulers
095a8f6e18a69fdeb304bc80c4f778bf3bb93b73 # scx_maestro: Allow to enable/disable NUMA and SMT optimizations
462cdee26cbea4cb6a4a3b48ce18dedd9730e12e # scx_maestro: Don't update deadline in case of re-enqueue
ff1f012d3c5fee3513808cb84c71be1c07ab2cc9 # scx_maestro: Introduce completely fair scheduling
d0284765e3725e736db70246b40722a33ebc421e # scx_maestro: Make enqueue + CPU kick more reliable
aacae22073b4d32c60878007a59211482bc5fdfb # scx_flash: Use SCX_DSQ_LOCAL to direct dispatch per-CPU tasks
d61384d0e98c194630e8945122f6122602085a4f # Cargo: fix formatting
9f7ddea769c1b3a55579f49d072f204b6e9a7c22 # scx_maestro: add --completions flag for shell completion generation
bd527d394fc50d4ebd91da2c3fe5989a6af3e78e # Cargo: update dependencies to latest versions
)

_reverts=(
)

pkgver() {
  cd $_gitname
  git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd $_gitname

  local _c _l
   for _c in "${_backports[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git cherry-pick --mainline 1 --no-commit "${_c}"
   done
   for _c in "${_reverts[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git revert --mainline 1 --no-commit "${_c}"
   done

  local src
   for src in "${source[@]}"; do
     src="${src%%::*}"
     src="${src##*/}"
     [[ $src = *.patch ]] || continue
     echo "Applying patch $src..."
     patch -Np1 < "../$src"
   done

  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd $_gitname
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build \
     --profile=$_mode \
     --frozen \
     --all-features \
     --workspace \
     --exclude scx_rlfifo \
     --exclude scxcash \
     --exclude xtask \
     --exclude vmlinux_docify \
     --exclude scx_arena_selftests
}

package() {
  cd $_gitname

  # Install all built executables (skip .so and .d files)
  find target/$_mode \
    -maxdepth 1 -type f -executable ! -name '*.so' \
    -exec install -Dm755 -t "$pkgdir/usr/bin/" {} +
}
