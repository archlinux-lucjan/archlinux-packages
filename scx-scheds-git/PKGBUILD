2f03333718819531fd58002e96e634fc6cde8f44 # scheds: add --completions flag for shell completion generation
dc65d39bba73fff12093dba29eff9616132907de # scheds: Introduce scx_maestro
24830cc3ead45e5af6451f370c8aed12fa6fad76 # scx_maestro: Honor cgroup cpu.weight for tasks and sub-schedulers
4449039dfd39435d8f816074a6b440ac188973a7 # scx_maestro: Allow to enable/disable NUMA and SMT optimizations
79b0c2efea733f0683d0e0315e66a8f7142dc531 # scx_maestro: Don't update deadline in case of re-enqueue
395c28a286cfb7e3adbd81fffe3342a508282f6e # scx_maestro: Introduce completely fair scheduling
