dccbb78e2668ac8825fdb375f2860bbf0cfcecdd # scx_pandemonium: bump to 5.9.0
73006ba7ccc7b3ffa5cc7b2889c546728c98a8d9 # scheds: add --completions flag for shell completion generation
e231964710ee65c482e1eb77b22719fa31b860b5 # scheds: Introduce scx_maestro
3a9c3136e480704d803b016d59931cc70935821f # scx_maestro: Honor cgroup cpu.weight for tasks and sub-schedulers
fec9304f510233350763816ae0099dde0945bcc5 # scx_maestro: Allow to enable/disable NUMA and SMT optimizations
f1c5f922356dd08d5b16a6694593a59081dd2737 # scx_maestro: Don't update deadline in case of re-enqueue
46f1b203de5dc4ce15404827c8e5191fc4c6e86d # scx_maestro: Introduce completely fair scheduling
77e1e9f0b6cd3559a3b6c26ece7fb7804bd5c521 # scx_maestro: Make enqueue + CPU kick more reliable
7c8a076bd2c68c218a3b05cf4b44ee16189c210e # scx_flash: Use SCX_DSQ_LOCAL to direct dispatch per-CPU tasks
5293e0613b796c108b5d5d9274017fb0e01a35a9 # Cargo: fix formatting
24f228049a70487318077bd60e00d59fc3be2d9a # scx_maestro: add --completions flag for shell completion generation
ea7dbc88993fd15c2c058757796339661fae70a7 # Cargo: update dependencies to latest versions
)

_reverts=(
)

pkgver() {
  cd $_gitname
  git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd $_gitname

  local _c _l
   for _c in "${_backports[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git cherry-pick --mainline 1 --no-commit "${_c}"
   done
   for _c in "${_reverts[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git revert --mainline 1 --no-commit "${_c}"
   done

  local src
   for src in "${source[@]}"; do
     src="${src%%::*}"
     src="${src##*/}"
     [[ $src = *.patch ]] || continue
     echo "Applying patch $src..."
     patch -Np1 < "../$src"
   done

  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd $_gitname
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build \
     --profile=$_mode \
     --frozen \
     --all-features \
     --workspace \
     --exclude scx_rlfifo \
     --exclude scxcash \
     --exclude xtask \
     --exclude vmlinux_docify \
     --exclude scx_arena_selftests
}

package() {
  cd $_gitname

  # Install all built executables (skip .so and .d files)
  find target/$_mode \
    -maxdepth 1 -type f -executable ! -name '*.so' \
    -exec install -Dm755 -t "$pkgdir/usr/bin/" {} +
}
