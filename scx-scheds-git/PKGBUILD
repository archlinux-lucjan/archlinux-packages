# Available profiles: “release”, “release-tiny”, “release-fast“
# See: https://github.com/sched-ext/scx/blob/main/Cargo.toml
_mode=release

pkgname=scx-scheds-git
_gitname=scx
pkgver=1.1.0.r357.gd639b45a
pkgrel=2
pkgdesc='sched_ext schedulers and tools'
url='https://github.com/sched-ext/scx'
arch=('x86_64')
license=('GPL-2.0-only')
depends=(
  jq
  libseccomp
  libelf
  zlib
)
makedepends=(
  cargo
  clang
  git
  llvm
  llvm-libs
  python
)
optdepends=(
'scx-tools: scx_loader and scxctl - A DBUS Interface for Managing sched_ext Schedulers '
)
options=(!lto)
provides=("scx-scheds")
conflicts=("scx-scheds")
source=("git+https://github.com/sched-ext/scx")
sha256sums=('SKIP')

_backports=(
60cc5e7d6f01a6d7f89b89c3c6cb1a3bcab6ba8b # scx_cake: Sync Frontier optimizations onto latest upstream main
48cc156ce6060b80259c44372a7929804632bcd3 # scheds: Introduce scx_maestro
b82c02e3f4d43993e4141ff079481ffb7d22d195 # scx_maestro: Honor cgroup cpu.weight for tasks and sub-schedulers
a946b80cef05aee3bb6861966cf5d8e47d63df91 # scx_maestro: Allow to enable/disable NUMA and SMT optimizations
d0b2a0b5a8a78c9023ef0011650aa0d00e884331 # scx_maestro: Don't update deadline in case of re-enqueue
c5bef90630100c74aeb08acf0058febad7c27241 # scx_maestro: Introduce completely fair scheduling
a1a860c488dcc592be8d07c82b3bfcc6a89b2e4d # scx_maestro: Make enqueue + CPU kick more reliable
a5752de9afe25fcd3ddf33e9327b60105680e0ac # Cargo: fix formatting
5f307cac76695a37fb299c792985c516e3d528a6 # scx_maestro: add --completions flag for shell completion generation
ee0e0cad8c13449754d84e3ec3223f35a3bf3680 # scheds: add --completions flag for shell completion generation
73c593acad2f39c419e185a20978a68a7f7f36ee # Cargo: update dependencies to latest versions
)

_reverts=(
)

pkgver() {
  cd $_gitname
  git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd $_gitname

  local _c _l
   for _c in "${_backports[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git cherry-pick --mainline 1 --no-commit "${_c}"
   done
   for _c in "${_reverts[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git revert --mainline 1 --no-commit "${_c}"
   done

  local src
   for src in "${source[@]}"; do
     src="${src%%::*}"
     src="${src##*/}"
     [[ $src = *.patch ]] || continue
     echo "Applying patch $src..."
     patch -Np1 < "../$src"
   done

  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd $_gitname
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build \
     --profile=$_mode \
     --frozen \
     --all-features \
     --workspace \
     --exclude scx_rlfifo \
     --exclude scxcash \
     --exclude xtask \
     --exclude vmlinux_docify \
     --exclude scx_arena_selftests
}

package() {
  cd $_gitname

  # Install all built executables (skip .so and .d files)
  find target/$_mode \
    -maxdepth 1 -type f -executable ! -name '*.so' \
    -exec install -Dm755 -t "$pkgdir/usr/bin/" {} +
}
