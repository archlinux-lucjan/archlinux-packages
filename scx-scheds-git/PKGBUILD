# Available profiles: “release”, “release-tiny”, “release-fast“
# See: https://github.com/sched-ext/scx/blob/main/Cargo.toml
_mode=release

pkgname=scx-scheds-git
_gitname=scx
pkgver=1.1.0.r372.ga08c9e27
pkgrel=5
pkgdesc='sched_ext schedulers and tools'
url='https://github.com/sched-ext/scx'
arch=('x86_64')
license=('GPL-2.0-only')
depends=(
  jq
  libseccomp
  libelf
  zlib
)
makedepends=(
  cargo
  clang
  git
  llvm
  llvm-libs
  python
)
optdepends=(
'scx-tools: scx_loader and scxctl - A DBUS Interface for Managing sched_ext Schedulers '
)
options=(!lto)
provides=("scx-scheds")
conflicts=("scx-scheds")
source=("git+https://github.com/sched-ext/scx")
sha256sums=('SKIP')

_backports=(
63deae917a8840c5399a455bb83bf64b10c7cf96 # scx_pandemonium: bump to 5.7.0
1ff9697c84aa0cd1c913f454587fc6e609acf631 # scheds: add --completions flag for shell completion generation
1d15828953384998b9da189d75f727d7ba04fee6 # scheds: Introduce scx_maestro
2296a27791a26d9acbcbf91beaf02ec0370e87bb # scx_maestro: Honor cgroup cpu.weight for tasks and sub-schedulers
a2fac6210efd7b126f27669df4e899c3feefd82b # scx_maestro: Allow to enable/disable NUMA and SMT optimizations
5c5db8ce8a2b1cc60be38ca41b31f2fbd02ffb31 # scx_maestro: Don't update deadline in case of re-enqueue
5a13c5499581e723969afc4484beb1d626adb870 # scx_maestro: Introduce completely fair scheduling
deccbd8f0861259036faab35fcfc5b6761343a70 # scx_maestro: Make enqueue + CPU kick more reliable
1b9d8fb68f750d5cd4182c9169d490eec7cde2f7 # scx_flash: Use SCX_DSQ_LOCAL to direct dispatch per-CPU tasks
dedc28f6bfd01bc717d937be10f1cdd7e0a85198 # Cargo: fix formatting
826c93438564732553487ba3118c1e817919b6a7 # scx_maestro: add --completions flag for shell completion generation
91e1ddf57d36522c86c986f5fb7cd3510b5fa15b # Cargo: update dependencies to latest versions
)

_reverts=(
)

pkgver() {
  cd $_gitname
  git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd $_gitname

  local _c _l
   for _c in "${_backports[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git cherry-pick --mainline 1 --no-commit "${_c}"
   done
   for _c in "${_reverts[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git revert --mainline 1 --no-commit "${_c}"
   done

  local src
   for src in "${source[@]}"; do
     src="${src%%::*}"
     src="${src##*/}"
     [[ $src = *.patch ]] || continue
     echo "Applying patch $src..."
     patch -Np1 < "../$src"
   done

  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd $_gitname
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build \
     --profile=$_mode \
     --frozen \
     --all-features \
     --workspace \
     --exclude scx_rlfifo \
     --exclude scxcash \
     --exclude xtask \
     --exclude vmlinux_docify \
     --exclude scx_arena_selftests
}

package() {
  cd $_gitname

  # Install all built executables (skip .so and .d files)
  find target/$_mode \
    -maxdepth 1 -type f -executable ! -name '*.so' \
    -exec install -Dm755 -t "$pkgdir/usr/bin/" {} +
}
