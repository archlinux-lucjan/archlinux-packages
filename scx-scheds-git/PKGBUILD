# Available profiles: “release”, “release-tiny”, “release-fast“
# See: https://github.com/sched-ext/scx/blob/main/Cargo.toml
_mode=release

pkgname=scx-scheds-git
_gitname=scx
pkgver=1.1.0.r74.g948c2bb6
pkgrel=1
pkgdesc='sched_ext schedulers and tools'
url='https://github.com/sched-ext/scx'
arch=('x86_64')
license=('GPL-2.0-only')
depends=(
  jq
  libseccomp
  libelf
  zlib
)
makedepends=(
  cargo
  clang
  git
  llvm
  llvm-libs
  python
)
optdepends=(
'scx-tools: scx_loader and scxctl - A DBUS Interface for Managing sched_ext Schedulers '
)
options=(!lto)
provides=("scx-scheds")
conflicts=("scx-scheds")
source=("git+https://github.com/sched-ext/scx")
sha256sums=('SKIP')

_backports=(
af43a88321feb05bf713af050e3b4bcaf6ad8cb0 # scx_cosmos: perf: Look for least event-heavy idle CPU in the same LLC
e1286bb4112fbacc047098109f835dfa24739e41 # scx_cosmos: perf: Accept symbolic perf event names with -e and -y
17f6be9a354f345053b440c316379b34db66ac2f # scx_cosmos: perf: Improve dynamic perf threshold logic
558b1a7d573ec3fc000e3e64194e942f8c930698 # scx_cosmos: perf: Prevent starvation with sticky direct dispatch
518930f492e5e93de344128b460284b9bcb4421b # scx_cosmos: perf: Improve perf event idle CPU selection policy
8b3cec43e0feff55547967c5bdd37a1d567338f3 # scx_cosmos: Track per-CPU utilization instead of global CPU utilization
67560d9cec88dca87341f7d1009ff31b4997656a # scx_cosmos: Avoid migrating per-CPU tasks
f3c442ef4f1786d2cbe3a45ea5a540cccec1ff0b # scx_cosmos: Scale task time slice by CPU capacity
2177107dc3dc27dfbf89afc43a1d9df140d06324 # scx_cosmos: perf: Prevent starvation with perf event dispatches
9a9d536737b64f1d17050f7bfa225ce3844a179f # scx_cosmos: perf: Limit migrations to one per time slice
)

_reverts=(
)

pkgver() {
  cd $_gitname
  git describe --long --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd $_gitname

  local _c _l
   for _c in "${_backports[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git cherry-pick --mainline 1 --no-commit "${_c}"
   done
   for _c in "${_reverts[@]}"; do
     if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
     git log --oneline "${_l}" "${_c}"
     git revert --mainline 1 --no-commit "${_c}"
   done

  local src
   for src in "${source[@]}"; do
     src="${src%%::*}"
     src="${src##*/}"
     [[ $src = *.patch ]] || continue
     echo "Applying patch $src..."
     patch -Np1 < "../$src"
   done

  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd $_gitname
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build \
     --profile=$_mode \
     --frozen \
     --all-features \
     --workspace \
     --exclude scx_rlfifo \
     --exclude scx_wd40 \
     --exclude scxcash \
     --exclude xtask \
     --exclude vmlinux_docify \
     --exclude scx_arena_selftests
}

package() {
  cd $_gitname

  # Install all built executables (skip .so and .d files)
  find target/$_mode \
    -maxdepth 1 -type f -executable ! -name '*.so' \
    -exec install -Dm755 -t "$pkgdir/usr/bin/" {} +
}
