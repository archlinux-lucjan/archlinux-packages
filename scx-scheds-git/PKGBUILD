4fc7ff2e4d1e9367682c77ea26f8459adbd51c87 # scheds: add --completions flag for shell completion generation
6df7d8551389eb624099b40257c8df91c3cdedff # scheds: Introduce scx_maestro
a4de14100e7d1226cff2fa2eb3e30f77c6f27be9 # scx_maestro: Honor cgroup cpu.weight for tasks and sub-schedulers
2e25941a01cf5e96d2d0a40357017ebfae4a5143 # scx_maestro: Allow to enable/disable NUMA and SMT optimizations
dabb2017433111e9379163ee89d4a1aa9a423d4a # scx_maestro: Don't update deadline in case of re-enqueue
